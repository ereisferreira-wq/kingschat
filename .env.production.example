# ============================================================================
# KMenu AI - Production Environment Configuration
# ============================================================================
# IMPORTANTE: Altere TODOS os valores de "change-me-in-production"
# IMPORTANTE: Nunca commite este arquivo com valores reais no Git
# ============================================================================

# Node Environment
NODE_ENV=production
PORT=3000

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=kmenu_user
DB_PASS=change-me-in-production-use-strong-password-min-16-chars
DB_NAME=kmenu_ai_prod
# Ativar SSL para conexao com banco (recomendado em producao com nuvem)
# DB_SSL=true

# ============================================================================
# REDIS (Cache & Queue)
# ============================================================================
REDIS_PASSWORD=change-me-in-production-use-strong-password-min-16-chars
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379

# ============================================================================
# ENCRYPTION (AES-256-GCM para dados sensiveis)
# ============================================================================
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-in-production-use-strong-random-string-32-bytes

# ============================================================================
# JWT Authentication
# ============================================================================
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production-use-strong-random-string-32-bytes
JWT_REFRESH_SECRET=change-me-in-production-use-strong-random-string-32-bytes

# ============================================================================
# Admin User (Criado automaticamente na primeira inicializacao)
# ============================================================================
ADMIN_EMAIL=admin@kingschat.com.br
ADMIN_PASSWORD=change-me-in-production-use-strong-password

# ============================================================================
# AI Providers
# ============================================================================
AI_PROVIDER=openai
# Opcoes: openai, ollama, azureopenai
AI_MODEL=gpt-4o

# OpenAI API
OPENAI_API_KEY=sk-your-actual-openai-api-key-here

# Ollama (se usar local LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Azure OpenAI (opcional)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key-here

# ============================================================================
# PIX Payment Info (Configurado via env, nao hardcoded)
# ============================================================================
PIX_BANK=336 - Banco C6 S.A.
PIX_AGENCY=0001
PIX_ACCOUNT=37632361-2
PIX_CNPJ=41.543.276/0001-01
PIX_NAME=Nome do Beneficiario
PIX_KEY=chave-pix-aqui

# ============================================================================
# URLs (importantes para CORS e redirects)
# ============================================================================
# Use HTTPS em producao!
FRONTEND_URL=https://app.kingschat.com.br
BACKEND_URL=https://api.kingschat.com.br

# ============================================================================
# Frontend Port
# ============================================================================
FRONTEND_PORT=80

# ============================================================================
# Logs & Monitoring (Opcional)
# ============================================================================
LOG_LEVEL=info
# Exemplo: Sentry DSN para error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# WhatsApp Configuration (Opcional)
# ============================================================================
# Configurado via painel admin apos primeiro login
# WHATSAPP_QR_TIMEOUT=120

# ============================================================================
# Email Configuration (Opcional para notificacoes)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-app
# EMAIL_FROM=noreply@kingschat.com.br

# ============================================================================
# INSTRUCOES DE GERACAO DE SECRETS
# ============================================================================
# Para gerar strings aleatorias seguras, use:
#
# Linux/Mac:
#   openssl rand -hex 32
#
# Node.js:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# PowerShell:
#   [Convert]::ToBase64String([System.Random]::new().GetBytes(32))
# ============================================================================
